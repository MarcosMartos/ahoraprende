---
---
<!-- Modal de Producto -->
<div id="product-modal" class="fixed inset-0 z-50 flex items-center justify-center p-4 bg-slate-950/80 backdrop-blur-md hidden opacity-0 transition-opacity duration-300">
  <div class="bg-slate-900 border border-slate-800 w-full max-w-2xl rounded-2xl overflow-hidden shadow-2xl relative flex flex-col sm:flex-row transform scale-95 transition-transform duration-300 max-h-[90vh] sm:max-h-none overflow-y-auto">
    <button id="close-modal" class="absolute top-3 right-3 z-20 bg-slate-950/85 hover:bg-slate-800 text-slate-400 hover:text-white p-2.5 rounded-full border border-slate-800 transition-colors">✕</button>
    <div class="w-full sm:w-1/2 aspect-video sm:aspect-square bg-slate-950 relative shrink-0">
      <img id="modal-img" src="" alt="" class="w-full h-full object-cover" />
    </div>
    <div class="p-6 w-full sm:w-1/2 flex flex-col justify-between gap-4">
      <div class="space-y-2">
        <span id="modal-tag" class="text-blue-400 text-[11px] font-bold tracking-wider uppercase bg-blue-950/50 px-2.5 py-1 rounded border border-blue-900/40 inline-block"></span>
        <h2 id="modal-title" class="text-lg sm:text-xl font-bold text-white tracking-tight leading-tight"></h2>
        <p id="modal-brand" class="text-xs text-slate-400">Marca: <span class="text-slate-200 font-medium"></span></p>
        <p class="text-xs sm:text-sm text-slate-400 leading-relaxed pt-1">
          Garantía oficial y soporte directo en nuestro local técnico. Consultá por WhatsApp disponibilidad inmediata.
        </p>
      </div>
      <div class="space-y-3 pt-3 border-t border-slate-800">
        <div class="flex justify-between items-center">
          <span id="modal-price" class="text-xl sm:text-2xl font-extrabold text-white"></span>
          <span id="modal-stock" class="text-[11px] text-slate-400 bg-slate-950 px-2 py-0.5 rounded border border-slate-800"></span>
        </div>
        <button id="modal-add-btn" class="w-full bg-blue-600 hover:bg-blue-500 text-white font-semibold py-3 rounded-xl text-sm transition-all active:scale-[0.97]">
          🛒 Añadir al carrito
        </button>
      </div>
    </div>
  </div>
</div>

<!-- Sidebar del Carrito -->
<div id="cart-sidebar" class="fixed inset-0 z-50 invisible transition-all duration-300">
  <div id="cart-overlay" class="absolute inset-0 bg-slate-950/60 backdrop-blur-sm opacity-0 transition-opacity duration-300"></div>
  <div class="absolute right-0 top-0 h-full w-full sm:max-w-md bg-slate-900 border-l border-slate-800 p-4 sm:p-6 shadow-2xl flex flex-col translate-x-full transition-transform duration-300">
    <div class="flex justify-between items-center border-b border-slate-800 pb-4 shrink-0">
      <div class="flex items-center gap-2">
        <span class="text-xl">🛒</span>
        <h2 class="text-lg font-bold text-white">Tu Pedido</h2>
      </div>
      <button id="close-cart" class="bg-slate-950 hover:bg-slate-800 text-slate-400 hover:text-white px-3 py-1.5 rounded-xl border border-slate-800 text-xs font-semibold">
        Cerrar ✕
      </button>
    </div>
    <div id="cart-items-container" class="flex-grow overflow-y-auto my-4 space-y-3 pr-1 content-start"></div>
    <div class="border-t border-slate-800 pt-4 space-y-4 shrink-0">
      <div class="flex justify-between items-center">
        <span class="text-slate-400 text-sm font-medium">Total Estimado:</span>
        <span id="cart-total-price" class="text-xl sm:text-2xl font-bold text-white">$0</span>
      </div>
      <button id="whatsapp-checkout-btn" class="w-full bg-blue-600 hover:bg-blue-500 text-white font-semibold py-3.5 rounded-xl text-sm transition-all flex justify-center items-center gap-2">
        💬 Confirmar pedido por WhatsApp
      </button>
    </div>
  </div>
</div>