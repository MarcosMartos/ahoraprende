---
import ProductCard from './ProductCard.astro';
// 1. Importamos la función asíncrona desde el archivo donde configuramos Google Sheets
import { obtenerProductos } from '../data/products';

// 2. Resolvemos la promesa para traer los productos reales en tiempo de compilación
const productos = await obtenerProductos();
---

<section id="catalogo" class="max-w-7xl mx-auto px-4 py-12 scroll-mt-24 bg-transparent">
  <div class="flex flex-col lg:flex-row justify-between items-start lg:items-end gap-6 mb-10">
    <div class="space-y-1">
      <h2 class="text-3xl font-bold tracking-tight text-white">Catálogo de Productos</h2>
      <p class="text-slate-400 text-sm">Disponibilidad en tiempo real para retiro inmediato.</p>
    </div>
    
    <div class="flex flex-col sm:flex-row gap-4 w-full lg:w-auto items-stretch sm:items-center">
      <div class="relative flex-1 sm:w-64">
        <span class="absolute inset-y-0 left-0 flex items-center pl-3 pointer-events-none text-slate-400">
          🔍
        </span>
        <input 
          type="text" 
          id="product-search" 
          placeholder="Buscar producto, marca..." 
          class="w-full pl-9 pr-4 py-2 bg-slate-900 text-slate-200 placeholder-slate-500 text-sm rounded-xl border border-slate-800/80 focus:border-blue-500/50 focus:outline-none focus:ring-1 focus:ring-blue-500/50 transition-all"
        />
      </div>

      <div id="category-filters" class="flex flex-row gap-2 overflow-x-auto pb-2 sm:pb-0 scrollbar-none relative z-10 snap-x">
        <button data-category="Celulares" class="btn-filter bg-blue-600 text-white text-xs md:text-sm px-5 py-2 rounded-xl font-medium shadow-md transition-all whitespace-nowrap snap-start">Celulares</button>
        <button data-category="todos" class="btn-filter bg-slate-900 text-slate-400 hover:text-slate-200 text-xs md:text-sm px-5 py-2 rounded-xl font-medium border border-slate-800/80 transition-all whitespace-nowrap snap-start">Todos</button>
        <button data-category="AURICULARES" class="btn-filter bg-slate-900 text-slate-400 hover:text-slate-200 text-xs md:text-sm px-5 py-2 rounded-xl font-medium border border-slate-800/80 transition-all whitespace-nowrap snap-start">Auriculares</button>
        <button data-category="INFORMATICA" class="btn-filter bg-slate-900 text-slate-400 hover:text-slate-200 text-xs md:text-sm px-5 py-2 rounded-xl font-medium border border-slate-800/80 transition-all whitespace-nowrap snap-start">Informatica</button>
        <button data-category="PARLANTES" class="btn-filter bg-slate-900 text-slate-400 hover:text-slate-200 text-xs md:text-sm px-5 py-2 rounded-xl font-medium border border-slate-800/80 transition-all whitespace-nowrap snap-start">Parlantes</button>
      </div>
    </div>
  </div>

  <div id="products-grid" class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6">
    {/* 3. Mapeamos directamente la variable "productos" dinámica */}
    {productos.map((producto) => (
      <ProductCard producto={producto} />
    ))}
  </div>

  <div class="flex justify-center items-center gap-4 mt-12 pb-6">
    <button 
      id="btn-prev-page" 
      class="bg-slate-900 hover:bg-slate-800 disabled:opacity-40 disabled:hover:bg-slate-900 text-slate-300 border border-slate-800/80 px-5 py-2.5 rounded-xl text-xs md:text-sm font-medium transition-all cursor-pointer disabled:cursor-not-allowed select-none"
    >
      ← Anterior
    </button>
    
    <span id="page-info" class="text-xs text-slate-400 font-medium uppercase tracking-widest bg-slate-900/40 border border-slate-800/50 px-4 py-2.5 rounded-xl select-none">
      Página <span id="current-page-num" class="text-blue-400 font-bold">1</span>
    </span>

    <button 
      id="btn-next-page" 
      class="bg-slate-900 hover:bg-slate-800 disabled:opacity-40 disabled:hover:bg-slate-900 text-slate-300 border border-slate-800/80 px-5 py-2.5 rounded-xl text-xs md:text-sm font-medium transition-all cursor-pointer disabled:cursor-not-allowed select-none"
    >
      Siguiente →
    </button>
  </div>
</section>