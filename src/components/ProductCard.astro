---
interface Props {
  producto: {
    id: string | number;
    titulo: string;
    precio: number;
    imagen: string;
    marca: string;
    categoria: string;
    stock: number;
  };
}

const { producto } = Astro.props;
---

<div 
  class="producto-card bg-slate-900/60 backdrop-blur-sm border border-slate-800/80 rounded-2xl overflow-hidden flex flex-col group hover:border-blue-500/40 hover:bg-slate-900/90 transition-all duration-300 shadow-xl cursor-pointer"
  data-id={producto.id}
  data-titulo={producto.titulo}
  data-precio={producto.precio}
  data-imagen={producto.imagen}
  data-marca={producto.marca}
  data-categoria={producto.categoria}
  data-stock={producto.stock}
>
  <div class="relative overflow-hidden aspect-square bg-slate-950 border-b border-slate-800/50 open-modal-trigger">
    <img src={producto.imagen} alt={producto.titulo} class="object-cover w-full h-full group-hover:scale-105 transition-transform duration-500 brightness-95" />
    <span class="absolute top-3 left-3 bg-slate-900/90 backdrop-blur-md border border-slate-800 text-slate-300 text-[10px] uppercase tracking-widest font-bold px-2.5 py-1 rounded-lg">
      {producto.marca}
    </span>
  </div>
  <div class="p-5 flex flex-col flex-grow justify-between space-y-4">
    <div class="space-y-1.5 open-modal-trigger">
      <span class="text-blue-400 text-xs font-semibold tracking-wider uppercase">{producto.categoria}</span>
      <h3 class="font-bold text-slate-200 group-hover:text-blue-400 transition-colors line-clamp-2 text-base leading-snug">
        {producto.titulo}
      </h3>
    </div>
    <div class="space-y-4 pt-1">
      <div class="flex justify-between items-center open-modal-trigger">
        <span class="text-xl font-bold text-white">${producto.precio.toLocaleString('es-AR')}</span>
        <span class="text-slate-500 text-xs bg-slate-950 px-2 py-1 rounded-md border border-slate-900">
          Stock: <span class="text-slate-300 font-medium">{producto.stock} u.</span>
        </span>
      </div>
      <button class="btn-add-cart w-full bg-blue-950/60 hover:bg-blue-600 text-blue-400 hover:text-white border border-blue-500/20 font-medium py-3 rounded-xl text-sm transition-all active:scale-[0.97] flex justify-center items-center gap-2">
        <span>🛍️</span> <span>Añadir al carrito</span>
      </button>
    </div>
  </div>
</div>